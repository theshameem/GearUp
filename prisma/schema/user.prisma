model User {
  id           String  @id @default(uuid()) @db.Uuid
  name         String
  email        String  @unique
  phone        String? @unique
  password     String
  profileImage String?
  address      String?

  role   UserRole
  status UserStatus @default(ACTIVE)

  gearItems    GearItem[]
  rentalOrders RentalOrder[]
  reviews      Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}
