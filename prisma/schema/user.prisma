model User {
  id           String  @id @default(uuid()) @db.Uuid
  firstName    String
  lastName     String
  email        String  @unique
  phone        String? @unique
  password     String
  profileImage String?
  address      String?

  role   UserRole
  status UserStatus @default(ACTIVE)

  // Relations: will be added later

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  gearItems    GearItem[]
  rentalOrders RentalOrder[]
  reviews      Review[]

  @@map("users")
}
