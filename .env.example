# GearUp backend env (example)
NODE_ENV=production
PORT=5000
APP_URL=https://your-frontend.example.com

# Postgres pooled connection (Neon / Supabase / Render Postgres)
DATABASE_URL=postgres://user:password@host:5432/db?sslmode=require

BCRYPT_SALT_ROUNDS=12

JWT_ACCESS_SECRET=replace-me-with-32-bytes-of-random-data
JWT_REFRESH_SECRET=replace-me-with-32-bytes-of-random-data
JWT_ACCESS_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d

STRIPE_SECRET_KEY=sk_live_or_sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRODUCT_PRICE_ID=price_...
